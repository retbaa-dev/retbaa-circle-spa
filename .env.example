# .env.example — Retbaa Circle SPA
# Copiez ce fichier en .env et renseignez les valeurs
# NE JAMAIS committer le .env réel dans git

# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL (depuis : Supabase → Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key (depuis : Supabase → Settings → API → Project API keys → anon public)
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# ── Preview mode (optionnel) ─────────────────────────────────────────────────
# Token secret pour activer le mode ?preview=massata&token=XXX
# Laissez vide pour désactiver le mode preview
VITE_PREVIEW_TOKEN=retbaa-dev-XXXX

# ── Notes ────────────────────────────────────────────────────────────────────
# Les variables VITE_* sont exposées côté client (bundle JS).
# Ne mettez JAMAIS la service role key ici — elle est réservée au serveur (server/).
#
# Pour Vercel : configurez ces variables dans
# Settings → Environment Variables → Production / Preview / Development
